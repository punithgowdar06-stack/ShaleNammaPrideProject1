<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="#FFFFFF">

        <!-- TITLE (RED COLOR) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daily Meal Updates"
            android:textSize="24sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="#D32F2F"
            android:layout_marginBottom="15dp" />

        <!-- Monday -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Monday - Rice, Sambar, Banana"
                android:textSize="18sp"
                android:padding="15dp" />
        </androidx.cardview.widget.CardView>

        <!-- Tuesday -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tuesday - Chapati, Curry, Milk"
                android:textSize="18sp"
                android:padding="15dp" />
        </androidx.cardview.widget.CardView>

        <!-- Wednesday -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Wednesday - Lemon Rice, Egg, Fruit"
                android:textSize="18sp"
                android:padding="15dp" />
        </androidx.cardview.widget.CardView>

        <!-- Thursday -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Thursday - Pongal, Chutney, Banana"
                android:textSize="18sp"
                android:padding="15dp" />
        </androidx.cardview.widget.CardView>

        <!-- Friday -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Friday - Veg Biryani, Curd"
                android:textSize="18sp"
                android:padding="15dp" />
        </androidx.cardview.widget.CardView>

        <!-- Saturday -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="6dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Saturday - Upma, Sambar, Milk"
                android:textSize="18sp"
                android:padding="15dp" />
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>